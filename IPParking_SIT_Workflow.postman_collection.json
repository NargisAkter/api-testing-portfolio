          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = JSON.parse(responseBody);",
                  "let j=jsonData.length;",
                  "pm.environment.set(\"total_garage_ipparking\",j);",
                  "for(var i=0;i<jsonData.length;i++)",
                  "{",
                  "    var garage=jsonData[i].name;",
                  "    if(jsonData[i].id=='3')",
                  "    {",
                  "    pm.environment.set(\"ip_garage1_name\", garage);",
                  "    }",
                  "    if(jsonData[i].id=='4')",
                  "    {",
                  "    pm.environment.set(\"ip_garage2_name_\", garage);",
                  "    }",
                  "",
                  "}"
