        {
          "name": "Garage info & spots availability DEV",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = JSON.parse(responseBody);",
                  "var garageCapacity1 =",
                  "    pm.environment.get(\"total_spots_carpark1\");",
                  "var garageOccupancy1 =",
                  "    pm.environment.get(\"totalOccupiedSpots_carpark1\");",
                  "var spotsAvailable_Carpark1= garageCapacity1-garageOccupancy1;",
                  "var garageCapacity2 =",
                  "    pm.environment.get(\"total_spots_carpark2\");",
                  "var garageOccupancy2 =",
                  "    pm.environment.get(\"totalOccupiedSpots_carpark2\");",
                  "var spotsAvailable_Carpark2= garageCapacity2-garageOccupancy2;",
                  "",
                  "for(var i=0;i<jsonData.data.parking.length;i++)",
                  "{",
                  "   if(jsonData.data.parking[i].garageName== \"Garage 2\")",
                  "   {",
                  "       pm.test(\"Validating garage name, capacity,occupancy and spots availabilty for Tower Garage in IPParking and APP_API\", function () {",
                  "    pm.expect(jsonData.data.parking[i].garageCapacity).to.eql(parseInt(pm.environment.get(\"total_spots_carpark1\")));",
                  "    pm.expect(jsonData.data.parking[i].garageOccupancy).to.eql(parseInt(pm.environment.get(\"totalOccupiedSpots_carpark1\")));",
                  "    pm.expect(parseInt(jsonData.data.parking[i].garageAvailability)).to.eql(spotsAvailable_Carpark1);",
                  "   }",
                  " )}",
                  "  if(jsonData.data.parking[i].garageName== \"Garage 2\")",
                  "   {",
                  "       pm.test(\"Validating garage name,capacity,occupancy and spots availabilty for Garage 11 in IPParking and APP_API\", function () {",
                  "    pm.expect(jsonData.data.parking[i].garageCapacity).to.eql(parseInt(pm.environment.get(\"total_spots_carpark2\")));",
                  "    pm.expect(jsonData.data.parking[i].garageOccupancy).to.eql(parseInt(pm.environment.get(\"totalOccupiedSpots_carpark2\")));",
                  "    pm.expect(parseInt(jsonData.data.parking[i].garageAvailability)).to.eql(spotsAvailable_Carpark2);",
                  "   }",
                  " )}",
                  "}",
                  "    pm.test(\"Validating total garage number in IPParking and APP_API\", function () {",
                  "    pm.expect(i).to.eql(parseInt(pm.environment.get(\"total_garage_ipparking\")));",
                  "})",
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
